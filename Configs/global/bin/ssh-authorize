#!/usr/bin/env python3
# Copies the SSH public keys for whoever owns this script into the
# authorized_keys file for whoever runs it

import os
import sys
from glob import glob
from pathlib import Path

this_file = Path(__file__)
user_to_authorize = this_file.owner()
whoami = os.getlogin()


def help():
    print(__file__)
    print(f"Grants SSH access to user {user_to_authorize}")
    print()
    print("Options:")
    print("  --dryrun -d   Don't perform the operation, instead print what")
    print("                would have happened.")
    print("  --help -h     Display this message.")
    exit(1)


if "--help" in sys.argv or "-h" in sys.argv:
    help()

dryrun = user_to_authorize == whoami or "-d" in sys.argv or "--dryrun" in sys.argv

if not dryrun:
    print(f"""
    
                                WARNING!!!
                                ==========
    
    This script will grant the user '{user_to_authorize}' access to user 
    '{whoami}' over SSH.
    
    Do not run this script unless you trust {user_to_authorize} with full 
    access to the account {whoami}!
    
    """)
    
    if input(f"Grant access to {user_to_authorize}? (y/N): ").lower()[0] != "y":
        print("Exiting without changes")
        exit(2)
    authorized_keys = open(Path.home() / ".ssh" / "authorized_keys", "a")
else:
    print(f"Dryrun of granting {user_to_authorize} SSH access to {whoami}.")
    print("No changes will be made.")
    authorized_keys = sys.stdout

try:
    ssh_glob = Path(f"~{user_to_authorize}/.ssh").expanduser() / "id_*.pub"
    ssh_keys = glob(str(ssh_glob))
except Exception as e:
    print("Error globbing SSH keys:")
    print(e)
    exit(3)

read_error = False

for keyfile in ssh_keys:
    try:
        key = open(keyfile).read().strip()
        print(f"+ {keyfile}")
        authorized_keys.write(f"{key}\n")
    except Exception as e:
        print(f"Unable to read keyfile {keyfile}:")
        print(e)
        read_error = True


if read_error:
    exit(4)
